{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "settings"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-position",
    "opener:default",
    "os:default",
    "store:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/mulaRahul"
        },
        {
          "url": "https://discord.gg/er9pddccyS"
        }
      ]
    }
  ]
}